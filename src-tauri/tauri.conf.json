{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FluidState",
  "version": "0.5.6",
  "identifier": "com.fluidstate.app",
  "build": {
    "frontendDist": "../out/renderer",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "FluidState",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.anthropic.com; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null
    }
  }
}
