{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FluidState default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-size",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
