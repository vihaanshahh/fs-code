#!/usr/bin/env bash
# FluidState CLI launcher — opens the FluidState app with the given directory.
# Bundled inside the app; a symlink at /usr/local/bin/fluidstate points here.

set -euo pipefail

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  echo "Usage: fluidstate [directory]"
  echo ""
  echo "Open FluidState IDE in the specified directory (defaults to current directory)."
  echo ""
  echo "Examples:"
  echo "  fluidstate              Open in current directory"
  echo "  fluidstate .            Open in current directory"
  echo "  fluidstate ~/projects   Open in ~/projects"
  exit 0
fi

if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
  echo "FluidState CLI"
  exit 0
fi

# Resolve target directory
TARGET_DIR="${1:-.}"
if [ ! -d "$TARGET_DIR" ]; then
  echo "Error: '$TARGET_DIR' is not a directory" >&2
  exit 1
fi
TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

# Resolve this script's real location (follows symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # Resolve relative symlinks
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# SCRIPT_DIR is <app>/Contents/Resources/bin  (macOS)
#               or <install>/resources/bin      (Linux / WSL)

# Detect WSL
IS_WSL=false
if grep -qi microsoft /proc/version 2>/dev/null; then
  IS_WSL=true
fi

if [ "$(uname)" = "Darwin" ]; then
  # macOS: SCRIPT_DIR = FluidState.app/Contents/Resources/bin
  # Go up to FluidState.app
  APP_BUNDLE="$(cd "$SCRIPT_DIR/../../.." && pwd)"
  if [ -d "$APP_BUNDLE" ] && [[ "$APP_BUNDLE" == *.app ]]; then
    open -a "$APP_BUNDLE" --args --open-dir="$TARGET_DIR"
  else
    echo "Error: Could not locate FluidState.app from $SCRIPT_DIR" >&2
    exit 1
  fi

elif [ "$IS_WSL" = true ]; then
  # WSL: SCRIPT_DIR is /mnt/c/.../resources/bin (Windows install accessed via WSL)
  # The Windows exe is at <install>/FluidState.exe → ../../FluidState.exe
  INSTALL_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
  WIN_EXEC=""
  for candidate in "$INSTALL_DIR/FluidState.exe" "$INSTALL_DIR/fluidstate.exe"; do
    if [ -f "$candidate" ]; then
      WIN_EXEC="$candidate"
      break
    fi
  done
  if [ -z "$WIN_EXEC" ]; then
    echo "Error: Could not locate FluidState.exe in $INSTALL_DIR" >&2
    exit 1
  fi

  # Convert paths to Windows format for the Windows process
  WIN_EXEC_PATH="$(wslpath -w "$WIN_EXEC")"
  WIN_TARGET_DIR="$(wslpath -w "$TARGET_DIR")"

  # Launch via cmd.exe so it starts detached from the WSL terminal
  cmd.exe /c start "" "$WIN_EXEC_PATH" --open-dir="$WIN_TARGET_DIR" 2>/dev/null

else
  # Native Linux: SCRIPT_DIR = <install>/resources/bin
  # The executable is at <install>/fluidstate (AppImage) or similar
  INSTALL_DIR="$(cd "$SCRIPT_DIR/../.." && pwd)"
  EXEC=""
  for candidate in "$INSTALL_DIR/fluidstate" "$INSTALL_DIR/FluidState"; do
    if [ -x "$candidate" ]; then
      EXEC="$candidate"
      break
    fi
  done
  if [ -z "$EXEC" ]; then
    echo "Error: Could not locate FluidState executable in $INSTALL_DIR" >&2
    exit 1
  fi
  "$EXEC" --open-dir="$TARGET_DIR" &
  disown 2>/dev/null
fi
